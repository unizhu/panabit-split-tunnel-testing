# Cleanup any leftover routes (safety measure)
cleanup_routes()
{
    local i=1
    while [ $i -lt 100 ]; do
        ${FLOWEYE} route remove id=$((ROUTE_ID_BASE + i)) 2>/dev/null
        ${FLOWEYE} dnspolicy remove id=$((DNS_ID_BASE + i)) 2>/dev/null
        i=$((i + 1))
    done
}

# Main dispatcher
case "${CGI_action}" in
    "get_wan_list")
        retjson 0 "OK" "$(get_wan_list)"
        ;;
    "test_single_wan")
        retjson 0 "OK" "$(test_single_wan "${CGI_wan_name}")"
        ;;
    "test_single")
        retjson 0 "OK" "$(test_single_endpoint "${CGI_endpoint_id}")"
        ;;
    "test_wan")
        cleanup_routes
        retjson 0 "OK" "$(test_wan_routing)"
        ;;
    "test_default")
        retjson 0 "OK" "$(test_default_route)"
        ;;
    "cleanup")
        cleanup_routes
        retjson 0 "Routes cleaned"
        ;;
    *)
        retjson 1 "Unknown action"
        ;;
esac
